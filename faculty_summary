<?php
include "config.php";
header('Content-Type: application/json');

// AJAX-safe session check — returns JSON on expiry, not HTML redirect
if (!isset($_SESSION['user_id'])) { echo json_encode(['error'=>'session_expired']); exit(); }
define('SESSION_TIMEOUT', 300);
if (isset($_SESSION['last_activity']) && (time()-$_SESSION['last_activity'])>SESSION_TIMEOUT) {
    session_unset(); session_destroy();
    echo json_encode(['error'=>'session_expired']); exit();
}
$_SESSION['last_activity']   = time();
$_SESSION['session_expires'] = time()+SESSION_TIMEOUT;

$uid = intval($_SESSION['user_id']);
$chk = mysqli_query($conn,"SELECT role FROM users WHERE id='$uid' LIMIT 1");
if (!$chk||mysqli_num_rows($chk)===0||mysqli_fetch_assoc($chk)['role']!=='admin') {
    echo json_encode(['error'=>'unauthorized']); exit();
}

$month = intval($_GET['month'] ?? date('n'));
$year  = intval($_GET['year']  ?? date('Y'));
if ($month<1||$month>12||$year<2000||$year>2100) { echo json_encode(['error'=>'invalid_params']); exit(); }

$month_str = date('F', mktime(0,0,0,$month,1));
$month_pad = str_pad($month,2,'0',STR_PAD_LEFT);
$date_end  = date('Y-m-t', mktime(0,0,0,$month,1,$year));

$res = mysqli_query($conn,"
    SELECT f.name, f.department,
        COUNT(r.id) AS review_count,
        ROUND(AVG(r.rating_teaching),1)      AS avg_teaching,
        ROUND(AVG(r.rating_communication),1) AS avg_communication,
        ROUND(AVG(r.rating_punctuality),1)   AS avg_punctuality,
        ROUND(AVG(r.rating_fairness),1)      AS avg_fairness,
        ROUND(AVG(r.rating_overall),1)       AS avg_overall,
        SUM(CASE WHEN r.sentiment='positive' THEN 1 ELSE 0 END) AS positive_count,
        SUM(CASE WHEN r.sentiment='negative' THEN 1 ELSE 0 END) AS negative_count,
        SUM(CASE WHEN r.sentiment='neutral'  THEN 1 ELSE 0 END) AS neutral_count
    FROM faculties f
    LEFT JOIN reviews r ON r.faculty_id=f.id AND r.status='approved'
        AND r.created_at BETWEEN '{$year}-{$month_pad}-01 00:00:00' AND '$date_end 23:59:59'
    GROUP BY f.id,f.name,f.department
    HAVING review_count>0
    ORDER BY avg_overall DESC, review_count DESC
");

if (!$res||mysqli_num_rows($res)===0) {
    echo json_encode(['summary'=>"No approved reviews were found for $month_str $year. There is no data available to generate a performance summary for this period."]); exit();
}

$faculty_data=[];
while ($row=mysqli_fetch_assoc($res)) $faculty_data[]=$row;

$data_lines=[];
foreach ($faculty_data as $f) {
    $data_lines[] = sprintf(
        "- %s (%s): %d review(s) | Teaching:%s | Communication:%s | Punctuality:%s | Fairness:%s | Overall:%s | Sentiment: %d positive, %d negative, %d neutral",
        $f['name'], $f['department']?:'No Dept', $f['review_count'],
        $f['avg_teaching']?:'N/A', $f['avg_communication']?:'N/A',
        $f['avg_punctuality']?:'N/A', $f['avg_fairness']?:'N/A', $f['avg_overall']?:'N/A',
        $f['positive_count'], $f['negative_count'], $f['neutral_count']
    );
}

$prompt = "You are an academic performance analyst. Below is faculty performance data from student reviews for $month_str $year.

DATA (".count($faculty_data)." faculty members with reviews):
".implode("\n",$data_lines)."

Write a structured monthly performance summary report with:
1. Overall performance overview for the month
2. Top performing faculty members
3. Areas of concern (if any scored consistently low)
4. Department-level observations
5. Short recommendation for administration

Professional tone, plain text only — no markdown, no asterisks, no bullet symbols. Use numbered sections. Maximum 400 words.";

$env = parse_ini_file(__DIR__.'/.env');
$api_key = $env['GROQ_API_KEY']??'';
if (empty($api_key)) { echo json_encode(['error'=>'API key not configured']); exit(); }

$payload = json_encode(['model'=>'llama-3.3-70b-versatile','max_tokens'=>600,
    'messages'=>[
        ['role'=>'system','content'=>'You are a professional academic performance analyst. Write clear reports in plain text only.'],
        ['role'=>'user','content'=>$prompt]
    ]]);

$ch = curl_init('https://api.groq.com/openai/v1/chat/completions');
curl_setopt_array($ch,[CURLOPT_RETURNTRANSFER=>true,CURLOPT_POST=>true,CURLOPT_POSTFIELDS=>$payload,CURLOPT_TIMEOUT=>30,
    CURLOPT_HTTPHEADER=>['Content-Type: application/json','Authorization: Bearer '.$api_key]]);
$response=curl_exec($ch); $curl_err=curl_error($ch); curl_close($ch);

if ($curl_err) { echo json_encode(['error'=>'Network error: '.$curl_err]); exit(); }
$data=json_decode($response,true);
$summary=$data['choices'][0]['message']['content']??null;
if (!$summary) { echo json_encode(['error'=>'AI did not return a response. Please try again.']); exit(); }
echo json_encode(['summary'=>trim($summary)]);